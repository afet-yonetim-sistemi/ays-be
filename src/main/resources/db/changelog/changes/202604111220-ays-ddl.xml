<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.10.xsd">

    <changeSet id="202604111220-ays-ddl" author="ays">
        <!-- ==================================== -->
        <!-- DDL of AYS_USER_INSTITUTION_RELATION -->
        <!-- ==================================== -->
        <createTable tableName="AYS_USER_INSTITUTION_RELATION">
            <column name="ID" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="USER_ID" type="VARCHAR(36)">
                <constraints nullable="false"
                             foreignKeyName="FK__AYS_USER_INSTITUTION_RELATION__USER_ID"
                             referencedTableName="AYS_USER"
                             referencedColumnNames="ID"/>
            </column>
            <column name="INSTITUTION_ID" type="VARCHAR(36)">
                <constraints nullable="false"
                             foreignKeyName="FK__AYS_USER_INSTITUTION_RELATION__INSTITUTION_ID"
                             referencedTableName="AYS_INSTITUTION"
                             referencedColumnNames="ID"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="AYS_USER_INSTITUTION_RELATION"
                             columnNames="USER_ID, INSTITUTION_ID"
                             constraintName="UI__AYS_USER_INSTITUTION_RELATION__USER_ID__INSTITUTION_ID"
        />

        <createIndex tableName="AYS_USER_INSTITUTION_RELATION"
                     indexName="I__AYS_USER_INSTITUTION_RELATION__USER_ID"
        >
            <column name="USER_ID"/>
        </createIndex>

        <createIndex tableName="AYS_USER_INSTITUTION_RELATION"
                     indexName="I__AYS_USER_INSTITUTION_RELATION__INSTITUTION_ID"
        >
            <column name="INSTITUTION_ID"/>
        </createIndex>
        <!-- ==================================== -->
        <!-- DDL of AYS_USER_INSTITUTION_RELATION -->
        <!-- ==================================== -->


        <!-- ==================================== -->
        <!-- DML of AYS_USER_INSTITUTION_RELATION -->
        <!-- ==================================== -->
        <sql>
            INSERT INTO AYS_USER_INSTITUTION_RELATION (USER_ID, INSTITUTION_ID)
            SELECT ID, INSTITUTION_ID
            FROM AYS_USER
        </sql>
        <!-- ==================================== -->
        <!-- DML of AYS_USER_INSTITUTION_RELATION -->
        <!-- ==================================== -->


        <!-- =============== -->
        <!-- DDL of AYS_USER -->
        <!-- =============== -->
<!--        <dropForeignKeyConstraint baseTableName="AYS_USER" constraintName="FK__AYS_USER__INSTITUTION_ID"/>-->
        <dropColumn tableName="AYS_USER" columnName="INSTITUTION_ID"/>
        <!-- =============== -->
        <!-- DDL of AYS_USER -->
        <!-- =============== -->
    </changeSet>

</databaseChangeLog>
