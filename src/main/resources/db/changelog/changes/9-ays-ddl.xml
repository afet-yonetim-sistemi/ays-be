<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.10.xsd">

    <changeSet id="9-ays-ddl" author="ays">
        <!-- ====================== -->
        <!-- DDL of AYS_SOS_MESSAGE -->
        <!-- ====================== -->
        <createTable tableName="AYS_SOS_MESSAGE">
            <column name="ID" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="SOS_ID" type="VARCHAR(36)">
                <constraints nullable="false"
                             foreignKeyName="FK__AYS_SOS_MESSAGE__SOS_ID"
                             referencedTableName="AYS_SOS"
                             referencedColumnNames="ID"
                />
            </column>
            <column name="SENDER_TYPE" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="SENDER_ID" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="MESSAGE" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="IMAGE_URL" type="MEDIUMTEXT">
                <constraints nullable="true"/>
            </column>
            <column name="CREATED_USER" type="VARCHAR(255)" defaultValue="AYS">
                <constraints nullable="false"/>
            </column>
            <column name="CREATED_AT" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="UPDATED_USER" type="VARCHAR(255)"/>
            <column name="UPDATED_AT" type="TIMESTAMP"/>
        </createTable>
        <!-- ====================== -->
        <!-- DDL of AYS_SOS_MESSAGE -->
        <!-- ====================== -->
    </changeSet>

</databaseChangeLog>
