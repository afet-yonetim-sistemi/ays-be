<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.10.xsd">

    <changeSet id="202604051938-ays-ddl" author="ays">
        <!-- ================= -->
        <!-- DDL of AYS_ADVERT -->
        <!-- ================= -->
        <createTable tableName="AYS_ADVERT">
            <column name="ID" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="INSTITUTION_ID" type="VARCHAR(36)">
                <constraints nullable="false"
                             foreignKeyName="FK__AYS_ADVERT__INSTITUTION_ID"
                             referencedTableName="AYS_INSTITUTION"
                             referencedColumnNames="ID"
                />
            </column>
            <column name="TITLE" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="DESCRIPTION" type="MEDIUMTEXT">
                <constraints nullable="false"/>
            </column>
            <column name="PARTICIPATION_TYPE" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="MAXIMUM_PARTICIPATION_COUNT" type="INTEGER(3)">
                <constraints nullable="false"/>
            </column>
            <column name="ADDRESS" type="VARCHAR(250)"/>
            <column name="CITY" type="VARCHAR(100)"/>
            <column name="EXTERNAL_LINK" type="VARCHAR(2048)"/>
            <column name="APPLICATION_DEADLINE" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="STARTED_AT" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="FINISHED_AT" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="STATUS" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="ACCESSIBILITY" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="CREATED_USER" type="VARCHAR(255)" defaultValue="AYS">
                <constraints nullable="false"/>
            </column>
            <column name="CREATED_AT" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="UPDATED_USER" type="VARCHAR(255)"/>
            <column name="UPDATED_AT" type="TIMESTAMP"/>
        </createTable>

        <createIndex
                tableName="AYS_ADVERT"
                indexName="I__AYS_ADVERT__INSTITUTION_ID"
        >
            <column name="INSTITUTION_ID"/>
        </createIndex>

        <createIndex
                tableName="AYS_ADVERT"
                indexName="I__AYS_ADVERT__PARTICIPATION_TYPE"
        >
            <column name="PARTICIPATION_TYPE"/>
        </createIndex>

        <createIndex
                tableName="AYS_ADVERT"
                indexName="I__AYS_ADVERT__CITY"
        >
            <column name="CITY"/>
        </createIndex>

        <createIndex
                tableName="AYS_ADVERT"
                indexName="I__AYS_ADVERT__STATUS"
        >
            <column name="STATUS"/>
        </createIndex>

        <createIndex
                tableName="AYS_ADVERT"
                indexName="I__AYS_ADVERT__MAXIMUM_PARTICIPATION_COUNT"
        >
            <column name="MAXIMUM_PARTICIPATION_COUNT"/>
        </createIndex>

        <createIndex
                tableName="AYS_ADVERT"
                indexName="I__AYS_ADVERT__STARTED_AT"
        >
            <column name="STARTED_AT"/>
        </createIndex>

        <createIndex
                tableName="AYS_ADVERT"
                indexName="I__AYS_ADVERT__CREATED_AT"
        >
            <column name="CREATED_AT"/>
        </createIndex>

        <sql>
            ALTER TABLE `AYS_ADVERT`
                ADD CONSTRAINT `C__AYS_ADVERT__PARTICIPATION_TYPE` CHECK (`PARTICIPATION_TYPE` IN ('PHYSICALLY',
                                                                                                   'ONLINE'));

            ALTER TABLE `AYS_ADVERT`
                ADD CONSTRAINT `C__AYS_ADVERT__STATUS` CHECK (`STATUS` IN ('IN_APPLICATION_PROCESS',
                                                                           'IN_APPLICATION_EVALUATION_PROCESS',
                                                                           'COMPLETED',
                                                                           'CANCELLED'));
        </sql>
        <!-- ================= -->
        <!-- DDL of AYS_ADVERT -->
        <!-- ================= -->


        <!-- ============================= -->
        <!-- DDL of AYS_ADVERT_RESPONSIBLE -->
        <!-- ============================= -->
        <createTable tableName="AYS_ADVERT_RESPONSIBLE">
            <column name="ID" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="ADVERT_ID" type="VARCHAR(36)">
                <constraints nullable="false"
                             foreignKeyName="FK__AYS_ADVERT_RESPONSIBLE__ADVERT_ID"
                             referencedTableName="AYS_ADVERT"
                             referencedColumnNames="ID"
                />
            </column>
            <column name="USER_ID" type="VARCHAR(36)">
                <constraints nullable="false"
                             foreignKeyName="FK__AYS_ADVERT_RESPONSIBLE__USER_ID"
                             referencedTableName="AYS_USER"
                             referencedColumnNames="ID"
                />
            </column>
            <column name="CREATED_USER" type="VARCHAR(255)" defaultValue="AYS">
                <constraints nullable="false"/>
            </column>
            <column name="CREATED_AT" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="UPDATED_USER" type="VARCHAR(255)"/>
            <column name="UPDATED_AT" type="TIMESTAMP"/>
        </createTable>

        <sql>
            ALTER TABLE `AYS_ADVERT_RESPONSIBLE`
                ADD CONSTRAINT `U__AYS_ADVERT_RESPONSIBLE__ADVERT_ID__USER_ID` UNIQUE (`ADVERT_ID`, `USER_ID`);
        </sql>
        <!-- ============================= -->
        <!-- DDL of AYS_ADVERT_RESPONSIBLE -->
        <!-- ============================= -->


        <!-- ============================= -->
        <!-- DDL of AYS_ADVERT_APPLICATION -->
        <!-- ============================= -->
        <createTable tableName="AYS_ADVERT_APPLICATION">
            <column name="ID" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="ADVERT_ID" type="VARCHAR(36)">
                <constraints nullable="false"
                             foreignKeyName="FK__AYS_ADVERT_APPLICATION__ADVERT_ID"
                             referencedTableName="AYS_ADVERT"
                             referencedColumnNames="ID"
                />
            </column>
            <column name="USER_ID" type="VARCHAR(36)">
                <constraints nullable="false"
                             foreignKeyName="FK__AYS_ADVERT_APPLICATION__USER_ID"
                             referencedTableName="AYS_USER"
                             referencedColumnNames="ID"
                />
            </column>
            <column name="HOURS_AVAILABLE_PER_DAY" type="INTEGER(2)">
                <constraints nullable="false"/>
            </column>
            <column name="STATUS" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="CREATED_USER" type="VARCHAR(255)" defaultValue="AYS">
                <constraints nullable="false"/>
            </column>
            <column name="CREATED_AT" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="UPDATED_USER" type="VARCHAR(255)"/>
            <column name="UPDATED_AT" type="TIMESTAMP"/>
        </createTable>

        <createIndex
                tableName="AYS_ADVERT_APPLICATION"
                indexName="I__AYS_ADVERT_APPLICATION__STATUS"
        >
            <column name="STATUS"/>
        </createIndex>

        <sql>
            ALTER TABLE `AYS_ADVERT_APPLICATION`
                ADD CONSTRAINT `U__AYS_ADVERT_APPLICATION__ADVERT_ID__USER_ID` UNIQUE (`ADVERT_ID`, `USER_ID`);

            ALTER TABLE `AYS_ADVERT_APPLICATION`
                ADD CONSTRAINT `C__AYS_ADVERT_APPLICATION__STATUS` CHECK (`STATUS` IN ('IN_REVIEW',
                                                                                       'APPROVED',
                                                                                       'REJECTED'));
        </sql>
        <!-- ============================= -->
        <!-- DDL of AYS_ADVERT_APPLICATION -->
        <!-- ============================= -->
    </changeSet>

</databaseChangeLog>
