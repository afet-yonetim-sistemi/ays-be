<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.10.xsd">

    <changeSet id="93-ays-dml" author="ays">
        <!-- Update Access Token Expiration to 48 hours (2880 min) -->
        <update tableName="AYS_PARAMETER">
            <column name="DEFINITION" value="2880"/>
            <where>NAME = 'AUTH_ACCESS_TOKEN_EXPIRE_MINUTE'</where>
        </update>

        <!-- Delete Legacy Refresh Token Day Param -->
        <delete tableName="AYS_PARAMETER">
            <where>NAME = 'AUTH_REFRESH_TOKEN_EXPIRE_DAY'</where>
        </delete>

        <!-- Ensure Refresh Token Minute Param is Clean -->
        <delete tableName="AYS_PARAMETER">
            <where>NAME = 'AUTH_REFRESH_TOKEN_EXPIRE_MINUTE'</where>
        </delete>

        <!-- Insert Refresh Token Expiration to 30 days (43200 min) -->
        <insert tableName="AYS_PARAMETER">
            <column name="NAME" value="AUTH_REFRESH_TOKEN_EXPIRE_MINUTE"/>
            <column name="DEFINITION" value="43200"/>
            <column name="CREATED_USER" value="AYS"/>
            <column name="CREATED_AT" valueDate="now()"/>
        </insert>
    </changeSet>

</databaseChangeLog>
